# secrets.toml.example
# ---------------------
# DO NOT commit the real secrets.toml — this file is just a template.
#
# For LOCAL dev:   copy this to .streamlit/secrets.toml and fill in real values
#                  (also add .streamlit/secrets.toml to .gitignore)
# For CLOUD deploy: paste these keys into the Streamlit Cloud dashboard
#                   App → Settings → Secrets
#
# ---------------------

OPENAI_API_KEY = "sk-..."

# Optional: set a password to protect the app from public access.
# Leave blank or remove this line to allow open access (e.g. local dev).
APP_PASSWORD = "your-password-here"
